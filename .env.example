NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — required for admin user management (invite, list, delete users).
# Find this in Supabase Dashboard → Settings → API → service_role key.
# NEVER expose this to the browser. Use only in server components and API routes.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
